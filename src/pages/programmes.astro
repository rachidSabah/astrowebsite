                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  {program.duration}
                </span>
              </div>
              <h3 class="text-2xl font-bold text-navy-900 mb-3">{program.title}</h3>
              <p class="text-navy-600 text-sm leading-relaxed mb-6">{program.description}</p>
              <div class="space-y-2">
                {program.highlights.map((highlight) => (
                  <div class="flex items-center gap-2 text-sm text-navy-700">
                    <svg class="w-5 h-5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                    <span>{highlight}</span>
                  </div>
                ))}
              </div>
              <div class="mt-6">
                <a href="/inscription" class="btn-primary text-sm px-6 py-3 w-full sm:w-auto text-center">
                  Postuler à Cette Formation
                </a>
              </div>
            </div>
          </div>
        ))}
