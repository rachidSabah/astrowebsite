              <span class="inline-block text-xs font-semibold text-primary-600 bg-primary-50 px-3 py-1 rounded-full mb-3">{step.subtitle}</span>
              <h3 class="text-xl font-bold text-navy-900 mb-3">{step.title}</h3>
              <p class="text-navy-600 text-sm leading-relaxed">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
