          {careerSteps.map((step, i) => (
            <div class="relative text-center animate-on-scroll" style={`animation-delay: ${i * 0.15}s`}>
              <!-- Step circle -->
              <div class={`w-20 h-20 mx-auto mb-6 rounded-full flex items-center justify-center text-white font-extrabold text-xl relative z-10 ${i === 0 ? 'bg-primary-400' : i === 1 ? 'bg-primary-500' : i === 2 ? 'bg-primary-600' : 'bg-primary-700'}`}>
