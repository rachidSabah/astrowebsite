---
import Layout from '../layouts/Layout.astro';

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Plan du site', url: '/plan-du-site' },
];

const mainPages = [
  {
    title: 'Accueil',
    url: '/',
    description: 'Page principale d\'INFOHAS Academy. Découvrez nos formations en aviation et rejoignez l\'élite du personnel navigant.',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>`,
  },
  {
    title: 'Programmes',
    url: '/programmes',
    description: 'Découvrez l\'ensemble de nos formations professionnelles : Hôtesse de l\'Air, Steward, Hôtesse d\'Accueil, Agent Aéroportuaire.',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>`,
  },
  {
    title: 'À Propos',
    url: '/a-propos',
    description: 'Apprenez-en plus sur INFOHAS Academy, notre histoire, nos valeurs et notre engagement envers l\'excellence dans la formation aéronautique.',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
  {
    title: 'Inscription',
    url: '/inscription',
    description: 'Remplissez notre formulaire de candidature en ligne pour rejoindre l\'une de nos formations professionnelles en aviation.',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>`,
  },
  {
    title: 'Contact',
    url: '/contact',
    description: 'Contactez notre équipe pour toute question sur nos formations, les modalités d\'inscription ou les débouchés professionnels.',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
  },
];

const legalPages = [
  {
    title: 'Mentions Légales',
    url: '/mentions-legales',
    description: 'Informations légales relatives à l\'éditeur, l\'hébergement et la propriété intellectuelle du site.',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
  },
  {
    title: 'Plan du Site',
    url: '/plan-du-site',
    description: 'Vue d\'ensemble de toutes les pages du site INFOHAS Academy.',
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" /></svg>`,
  },
];

const programs = [
  {
    title: 'Formation Hôtesse de l\'Air & Steward (PNC)',
    url: '/programmes#hotesse-de-lair',
    description: 'Formation complète au métier de Personnel Navigant Commercial.',
  },
  {
    title: 'Formation Hôtesse d\'Accueil',
    url: '/programmes#hotesse-accueil',
    description: 'Formation aux métiers de l\'accueil dans les espaces aéroportuaires.',
  },
  {
    title: 'Formation Agent de Services Aéroportuaires',
    url: '/programmes#agent-aeroportuaire',
    description: 'Formation aux opérations et services dans les aéroports.',
  },
];
---

<Layout
  title="Plan du Site"
  description="Plan du site INFOHAS Academy - Trouvez facilement la page qui vous intéresse parmi nos formations et informations."
  breadcrumbs={breadcrumbs}
  noindex={true}
>
  <!-- Hero -->
  <section class="relative bg-navy-950 py-16 md:py-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-primary-950 to-navy-900"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/90 via-navy-950/60 to-transparent"></div>
    <div class="container-max relative z-10">
      <span class="badge-primary text-sm px-4 py-2 inline-flex items-center mb-4">
        Navigation
      </span>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight">
        Plan du Site
      </h1>
      <p class="text-lg text-navy-200 mt-4 max-w-xl">
        Retrouvez facilement toutes les pages et sections du site INFOHAS Academy.
      </p>
    </div>
  </section>

  <!-- Main Pages -->
  <section class="section-padding bg-gray-50">
    <div class="container-max">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-navy-800 mb-8 animate-on-scroll flex items-center gap-3">
          <span class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center text-primary-600">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" /></svg>
          </span>
          Pages Principales
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {mainPages.map((page) => (
            <a href={page.url} class="card group animate-on-scroll hover:border-primary-200">
              <div class="w-10 h-10 bg-primary-50 rounded-lg flex items-center justify-center text-primary-600 mb-4 group-hover:bg-primary-100 transition-colors">
                <Fragment set:html={page.icon} />
              </div>
              <h3 class="text-base font-bold text-navy-800 mb-2 group-hover:text-primary-700 transition-colors">
                {page.title}
              </h3>
              <p class="text-sm text-navy-500 leading-relaxed">{page.description}</p>
              <div class="mt-4 flex items-center gap-1 text-xs font-semibold text-primary-600">
                <span>Visiter</span>
                <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Programs -->
  <section class="section-padding bg-white">
    <div class="container-max">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-navy-800 mb-8 animate-on-scroll flex items-center gap-3">
          <span class="w-10 h-10 bg-accent-100 rounded-lg flex items-center justify-center text-accent-700">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
          </span>
          Nos Formations
        </h2>
        <div class="space-y-3">
          {programs.map((prog) => (
            <a href={prog.url} class="card group animate-on-scroll flex items-center gap-4 hover:border-accent-200">
              <div class="w-10 h-10 bg-accent-50 rounded-lg flex items-center justify-center text-accent-700 flex-shrink-0 group-hover:bg-accent-100 transition-colors">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-bold text-navy-800 group-hover:text-accent-700 transition-colors truncate">
                  {prog.title}
                </h3>
                <p class="text-sm text-navy-500">{prog.description}</p>
              </div>
              <svg class="w-4 h-4 text-navy-300 group-hover:text-accent-600 group-hover:translate-x-1 transition-all flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Legal Pages -->
  <section class="section-padding bg-gray-50">
    <div class="container-max">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-navy-800 mb-8 animate-on-scroll flex items-center gap-3">
          <span class="w-10 h-10 bg-navy-100 rounded-lg flex items-center justify-center text-navy-600">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          </span>
          Informations Légales
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {legalPages.map((page) => (
            <a href={page.url} class="card group animate-on-scroll hover:border-navy-200">
              <div class="w-10 h-10 bg-navy-50 rounded-lg flex items-center justify-center text-navy-600 mb-4 group-hover:bg-navy-100 transition-colors">
                <Fragment set:html={page.icon} />
              </div>
              <h3 class="text-base font-bold text-navy-800 mb-2 group-hover:text-primary-700 transition-colors">
                {page.title}
              </h3>
              <p class="text-sm text-navy-500 leading-relaxed">{page.description}</p>
              <div class="mt-4 flex items-center gap-1 text-xs font-semibold text-primary-600">
                <span>Visiter</span>
                <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-white animate-on-scroll">
    <div class="container-max text-center">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold text-navy-900 mb-4">Vous ne trouvez pas ce que vous cherchez ?</h2>
        <p class="text-navy-600 mb-8">
          N'hésitez pas à nous contacter directement. Notre équipe se fera un plaisir de répondre à toutes vos questions.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/contact" class="btn-primary">
            Nous Contacter
            <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="tel:+212537762025" class="btn-secondary">
            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            +212 537 76 20 25
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
