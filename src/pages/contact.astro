---
import Layout from '../layouts/Layout.astro';

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Contact', url: '/contact' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact - INFOHAS Academy',
  description: 'Contactez INFOHAS Academy pour toute question sur nos formations en aviation. Hôtesse de l\'Air, Steward, Hôtesse d\'Accueil, Agent Aéroportuaire.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '15 Rue Demnate',
    addressLocality: 'Rabat',
    addressRegion: 'Hassan',
    addressCountry: 'MA',
  },
  telephone: '+212537762025',
  email: 'contact@infohas.ma',
};
---

<Layout
  title="Contactez-Nous"
  description="Contactez INFOHAS Academy pour toute question sur nos formations en aviation commerciale. Notre équipe vous répond sous 24h."
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLd}
>
  <!-- Hero Section -->
  <section class="relative bg-navy-950 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-primary-950 to-navy-900"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/90 via-navy-950/60 to-transparent"></div>
    <div class="absolute top-20 right-20 w-72 h-72 bg-primary-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 left-10 w-96 h-96 bg-accent-500/5 rounded-full blur-3xl"></div>

    <div class="container-max relative z-10 py-20 md:py-28">
      <div class="max-w-3xl">
        <span class="badge-primary text-sm px-4 py-2 inline-flex items-center mb-6">
          <span class="inline-block w-2 h-2 bg-primary-500 rounded-full mr-2 animate-pulse"></span>
          Nous sommes à votre écoute
        </span>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-white leading-[1.1] mb-6 text-balance animate-fade-in">
          Parlons de Votre <span class="gradient-text">Avenir dans l'Aviation</span>
        </h1>

        <p class="text-lg sm:text-xl text-navy-200 leading-relaxed max-w-2xl mb-8 animate-fade-in" style="animation-delay: 0.15s">
          Vous avez des questions sur nos formations, les modalités d'inscription ou les débouchés professionnels ? Notre équipe est à votre disposition pour vous accompagner.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Form + Sidebar -->
  <section class="section-padding bg-gray-50">
    <div class="container-max">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">

        <!-- Contact Form -->
        <div class="lg:col-span-2 animate-on-scroll">
          <div class="card p-0 overflow-hidden">
            <div class="bg-gradient-to-r from-primary-600 to-primary-800 px-6 md:px-8 py-6">
              <h2 class="text-2xl font-bold text-white">Envoyez-nous un Message</h2>
              <p class="text-primary-100 text-sm mt-1">Les champs marqués d'un astérisque (*) sont obligatoires. Réponse sous 24 à 48 heures.</p>
            </div>

            <form id="contact-form" class="p-6 md:p-8 space-y-6" novalidate>
              <!-- Name Row -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="first_name" class="label-text">Prénom *</label>
                  <input
                    type="text"
                    id="first_name"
                    name="first_name"
                    required
                    class="input-field"
                    placeholder="Votre prénom"
                    autocomplete="given-name"
                  />
                  <p class="text-red-500 text-xs mt-1 hidden" data-error="first_name"></p>
                </div>
                <div>
                  <label for="last_name" class="label-text">Nom *</label>
                  <input
                    type="text"
                    id="last_name"
                    name="last_name"
                    required
                    class="input-field"
                    placeholder="Votre nom de famille"
                    autocomplete="family-name"
                  />
                  <p class="text-red-500 text-xs mt-1 hidden" data-error="last_name"></p>
                </div>
              </div>

              <!-- Email + Phone Row -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="email" class="label-text">Adresse Email *</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="input-field"
                    placeholder="votre.email@exemple.com"
                    autocomplete="email"
                  />
                  <p class="text-red-500 text-xs mt-1 hidden" data-error="email"></p>
                </div>
                <div>
                  <label for="phone" class="label-text">Téléphone</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="input-field"
                    placeholder="06XXXXXXXX (facultatif)"
                    autocomplete="tel"
                  />
                  <p class="text-red-500 text-xs mt-1 hidden" data-error="phone"></p>
                </div>
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="label-text">Message *</label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="6"
                  class="input-field resize-y"
                  placeholder="Décrivez votre demande en quelques lignes..."
                ></textarea>
                <p class="text-red-500 text-xs mt-1 hidden" data-error="message"></p>
              </div>

              <!-- Submit -->
              <div class="pt-2">
                <button
                  type="submit"
                  id="contact-submit-btn"
                  class="btn-primary w-full sm:w-auto text-base px-10 py-4 flex items-center justify-center gap-2"
                >
                  <span id="contact-submit-text">Envoyer le Message</span>
                  <svg id="contact-submit-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                  </svg>
                  <svg id="contact-submit-spinner" class="w-5 h-5 animate-spin hidden" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                </button>
              </div>

              <!-- Messages -->
              <div id="contact-success" class="hidden p-4 bg-green-50 border border-green-200 rounded-lg">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <div>
                    <p class="font-semibold text-green-800">Message envoyé avec succès !</p>
                    <p class="text-green-700 text-sm mt-1">Nous vous répondrons dans les 24 à 48 heures ouvrables.</p>
                  </div>
                </div>
              </div>
              <div id="contact-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-lg">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-red-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <div>
                    <p class="font-semibold text-red-800">Erreur lors de l'envoi</p>
                    <p id="contact-error-message" class="text-red-700 text-sm mt-1"></p>
                  </div>
                </div>
              </div>
            </form>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <!-- Contact Info Card -->
          <div class="card animate-on-scroll">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-navy-800">Nos Coordonnées</h3>
            </div>
            <ul class="space-y-4">
              <li class="flex items-start gap-3 text-sm text-navy-600">
                <svg class="w-5 h-5 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <div>
                  <p class="font-semibold text-navy-800">Adresse</p>
                  <p>15 Rue Demnate, Hassan</p>
                  <p>10000 Rabat, Maroc</p>
                </div>
              </li>
              <li class="flex items-center gap-3 text-sm text-navy-600">
                <svg class="w-5 h-5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                <div>
                  <p class="font-semibold text-navy-800">Téléphone</p>
                  <a href="tel:+212537762025" class="hover:text-primary-600 transition-colors">+212 537 76 20 25</a>
                </div>
              </li>
              <li class="flex items-center gap-3 text-sm text-navy-600">
                <svg class="w-5 h-5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                <div>
                  <p class="font-semibold text-navy-800">Email</p>
                  <a href="mailto:contact@infohas.ma" class="hover:text-primary-600 transition-colors">contact@infohas.ma</a>
                </div>
              </li>
            </ul>
          </div>

          <!-- Social Links -->
          <div class="card animate-on-scroll">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 bg-accent-100 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-navy-800">Suivez-Nous</h3>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <a href="https://www.facebook.com/GroupeInfohas" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-3 py-2.5 rounded-lg bg-gray-50 hover:bg-primary-50 text-navy-600 hover:text-primary-700 transition-colors text-sm">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Facebook
              </a>
              <a href="https://www.instagram.com/infohas.cabincrew/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-3 py-2.5 rounded-lg bg-gray-50 hover:bg-primary-50 text-navy-600 hover:text-primary-700 transition-colors text-sm">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                Instagram
              </a>
              <a href="https://x.com/Groupeinfohas" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-3 py-2.5 rounded-lg bg-gray-50 hover:bg-primary-50 text-navy-600 hover:text-primary-700 transition-colors text-sm">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                X (Twitter)
              </a>
              <a href="https://www.linkedin.com/company-beta/5237641/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-3 py-2.5 rounded-lg bg-gray-50 hover:bg-primary-50 text-navy-600 hover:text-primary-700 transition-colors text-sm">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
              <a href="https://www.youtube.com/user/HOTESSE12" target="_blank" rel="noopener noreferrer" class="col-span-2 flex items-center gap-2 px-3 py-2.5 rounded-lg bg-gray-50 hover:bg-primary-50 text-navy-600 hover:text-primary-700 transition-colors text-sm">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                YouTube
              </a>
            </div>
          </div>

          <!-- Office Hours -->
          <div class="card animate-on-scroll">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-navy-800">Horaires d'Ouverture</h3>
            </div>
            <ul class="space-y-3 text-sm">
              <li class="flex justify-between items-center text-navy-600">
                <span>Lundi - Vendredi</span>
                <span class="font-semibold text-navy-800">09h00 - 18h00</span>
              </li>
              <li class="flex justify-between items-center text-navy-600">
                <span>Samedi</span>
                <span class="font-semibold text-navy-800">09h00 - 13h00</span>
              </li>
              <li class="flex justify-between items-center text-navy-400">
                <span>Dimanche</span>
                <span class="font-medium text-navy-400">Fermé</span>
              </li>
            </ul>
            <div class="mt-4 pt-4 border-t border-gray-100">
              <div class="flex items-center gap-2 text-sm text-accent-700 bg-accent-50 px-3 py-2 rounded-lg">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                <span>Réponse garantie sous 24-48h ouvrables</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="animate-on-scroll">
    <div class="container-max px-4 sm:px-6 lg:px-8 py-16">
      <div class="card p-0 overflow-hidden">
        <div class="bg-gradient-to-r from-primary-600 to-primary-800 px-6 md:px-8 py-5">
          <h2 class="text-xl font-bold text-white">Notre Emplacement</h2>
          <p class="text-primary-100 text-sm mt-1">15 Rue Demnate, Hassan, Rabat, Maroc</p>
        </div>
        <div class="relative bg-gray-200" style="height: 400px;">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3323.846!2d-6.6327!3d33.9891!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzPCsDU5JzIwLjgiTiA2wrAzNyc1Ny43Ilc!5e0!3m2!1sfr!2sma!4v1700000000000!5m2!1sfr!2sma"
            width="100%"
            height="100%"
            style="border:0; position:absolute; inset:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Localisation INFOHAS Academy - Rabat"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Bottom -->
  <section class="section-padding bg-white animate-on-scroll">
    <div class="container-max text-center">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold text-navy-900 mb-4">Prêt à Commencer Votre Formation ?</h2>
        <p class="text-navy-600 mb-8">
          Les inscriptions sont ouvertes pour la prochaine session. Ne manquez pas cette opportunité de rejoindre l'une des meilleures académies d'aviation au Maroc.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/inscription" class="btn-primary">
            S'inscrire Maintenant
            <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="/programmes" class="btn-secondary">
            Découvrir les Programmes
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('contact-submit-btn') as HTMLButtonElement;
  const submitText = document.getElementById('contact-submit-text') as HTMLElement;
  const submitIcon = document.getElementById('contact-submit-icon') as HTMLElement;
  const submitSpinner = document.getElementById('contact-submit-spinner') as HTMLElement;
  const successMsg = document.getElementById('contact-success')!;
  const errorMsg = document.getElementById('contact-error')!;
  const errorMessage = document.getElementById('contact-error-message')!;

  function showError(field: string, message: string) {
    const el = document.querySelector(`#contact-form [data-error="${field}"]`) as HTMLElement;
    if (el) {
      el.textContent = message;
      el.classList.remove('hidden');
    }
    const input = form?.querySelector(`[name="${field}"]`) as HTMLElement;
    if (input) input.classList.add('border-red-400', 'ring-1', 'ring-red-200');
  }

  function clearErrors() {
    form?.querySelectorAll('[data-error]').forEach(el => {
      el.classList.add('hidden');
      (el as HTMLElement).textContent = '';
    });
    form?.querySelectorAll('.input-field').forEach(el => {
      el.classList.remove('border-red-400', 'ring-1', 'ring-red-200');
    });
    errorMsg.classList.add('hidden');
    successMsg.classList.add('hidden');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErrors();

    const firstName = (form.querySelector('[name="first_name"]') as HTMLInputElement).value.trim();
    const lastName = (form.querySelector('[name="last_name"]') as HTMLInputElement).value.trim();
    const email = (form.querySelector('[name="email"]') as HTMLInputElement).value.trim();
    const phone = (form.querySelector('[name="phone"]') as HTMLInputElement).value.trim();
    const message = (form.querySelector('[name="message"]') as HTMLTextAreaElement).value.trim();

    let valid = true;

    if (!firstName) { showError('first_name', 'Le prénom est requis.'); valid = false; }
    if (!lastName) { showError('last_name', 'Le nom est requis.'); valid = false; }
    if (!email) {
      showError('email', 'L\'adresse email est requise.');
      valid = false;
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError('email', 'Veuillez entrer une adresse email valide.');
      valid = false;
    }
    if (!message) { showError('message', 'Le message est requis.'); valid = false; }

    if (!valid) return;

    // Show loading state
    submitBtn.disabled = true;
    submitText.textContent = 'Envoi en cours...';
    submitIcon.classList.add('hidden');
    submitSpinner.classList.remove('hidden');

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          first_name: firstName,
          last_name: lastName,
          email,
          phone,
          message,
        }),
      });

      const data = await response.json();

      if (response.ok && data.success) {
        successMsg.classList.remove('hidden');
        form.reset();
        window.scrollTo({ top: form.offsetTop - 100, behavior: 'smooth' });
      } else {
        errorMessage.textContent = data.error || 'Une erreur est survenue. Veuillez réessayer.';
        errorMsg.classList.remove('hidden');
      }
    } catch (err) {
      errorMessage.textContent = 'Erreur de connexion. Vérifiez votre connexion internet et réessayez.';
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitText.textContent = 'Envoyer le Message';
      submitIcon.classList.remove('hidden');
      submitSpinner.classList.add('hidden');
    }
  });
</script>
