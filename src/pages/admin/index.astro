---
import Layout from '../../layouts/Layout.astro';
import { getDB, getSubmissions, getSubmissionCount, getAllRedirects } from '../../lib/db';
import { requireAuth } from '../../lib/auth';

const env = (Astro.locals as any)?.runtime?.env;
const auth = await requireAuth(Astro.request, getDB(Astro), env);
if (!auth) return Astro.redirect('/admin/login');

const db = getDB(Astro);
const [enrollments, contacts, newCount, redirectResult] = await Promise.all([
  getSubmissions(db, 'enrollment'),
  getSubmissions(db, 'contact'),
  getSubmissionCount(db),
  getAllRedirects(db),
]);

const newSubmissions = (newCount?.count as number) || 0;
const totalEnrollments = (enrollments.results as any[]) || [];
const totalContacts = (contacts.results as any[]) || [];
const totalSubmissions = totalEnrollments.length + totalContacts.length;
const totalRedirects = (redirectResult.results as any[]) || [];

const recentSubmissions = [...totalEnrollments, ...totalContacts]
  .sort((a: any, b: any) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime())
  .slice(0, 5);

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
};

const statusBadge = (status: string) => {
  const map: Record<string, string> = {
    new: 'bg-blue-100 text-blue-700',
    read: 'bg-gray-100 text-gray-600',
    replied: 'bg-green-100 text-green-700',
    archived: 'bg-red-100 text-red-600',
  };
  const label: Record<string, string> = {
    new: 'Nouveau',
    read: 'Lu',
    replied: 'Répondu',
    archived: 'Archivé',
  };
  return `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ${map[status] || 'bg-gray-100 text-gray-600'}">${label[status] || status}</span>`;
};

const typeBadge = (type: string) => {
  return type === 'enrollment'
    ? '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-primary-100 text-primary-700">Candidature</span>'
    : '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-accent-100 text-accent-700">Contact</span>';
};

const currentPath = '/admin';
---

<Layout title="Tableau de bord — Administration" description="" noindex={true}>
  <div class="flex min-h-[calc(100vh-200px)]">
    <!-- Sidebar -->
    <aside class="w-64 bg-navy-900 text-white flex-shrink-0 hidden lg:flex flex-col">
      <div class="p-6 border-b border-navy-700">
