---
import Layout from '../../layouts/Layout.astro';
import { getDB, getSubmissions } from '../../lib/db';
import { requireAuth } from '../../lib/auth';

const env = (Astro.locals as any)?.runtime?.env;
const auth = await requireAuth(Astro.request, getDB(Astro), env);
if (!auth) return Astro.redirect('/admin/login');

const db = getDB(Astro);
const [enrollments, contacts] = await Promise.all([
  getSubmissions(db, 'enrollment'),
  getSubmissions(db, 'contact'),
]);

const enrollmentsList = (enrollments.results as any[]) || [];
const contactsList = (contacts.results as any[]) || [];

interface Submission {
  id: number;
  type: string;
  first_name: string;
  last_name: string;
  email: string;
  phone: string;
  program: string;
  message: string;
  education_level: string;
  date_of_birth: string;
  city: string;
  status: string;
  created_at: string;
}

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
};
---

<Layout title="Candidatures — Administration" description="" noindex={true}>
  <div class="flex min-h-[calc(100vh-200px)]">
    <!-- Sidebar -->
    <aside class="w-64 bg-navy-900 text-white flex-shrink-0 hidden lg:flex flex-col">
      <div class="p-6 border-b border-navy-700">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-gradient-to-br from-primary-500 to-primary-700 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <div>
            <p class="font-bold text-sm">INFOHAS Academy</p>
            <p class="text-xs text-navy-400">Administration</p>
          </div>
        </div>
      </div>
      <nav class="flex-1 p-4 space-y-1">
        <a href="/admin" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-navy-300 hover:bg-navy-800 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4" /></svg>
          Tableau de bord
        </a>
        <a href="/admin/submissions" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium bg-navy-800 text-white">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          Candidatures
        </a>
        <a href="/admin/content" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-navy-300 hover:bg-navy-800 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
          Contenu
        </a>
        <a href="/admin/seo" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-navy-300 hover:bg-navy-800 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          SEO & Meta
        </a>
        <a href="/admin/redirects" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-navy-300 hover:bg-navy-800 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          Redirections
        </a>
      </nav>
      <div class="p-4 border-t border-navy-700">
        <div class="flex items-center gap-3 px-3 py-2 mb-2">
          <div class="w-8 h-8 bg-primary-600 rounded-full flex items-center justify-center text-sm font-bold">
            {(auth.username || 'A').charAt(0).toUpperCase()}
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium truncate">{auth.username}</p>
            <p class="text-xs text-navy-400">Administrateur</p>
          </div>
        </div>
        <button id="logout-btn" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-navy-300 hover:bg-red-900/50 hover:text-red-300 transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
          Déconnexion
        </button>
      </div>
    </aside>

    <!-- Mobile Header -->
    <div class="lg:hidden fixed top-0 left-0 right-0 z-50 bg-navy-900 text-white px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 bg-gradient-to-br from-primary-500 to-primary-700 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
        </div>
        <span class="font-bold text-sm">Admin</span>
      </div>
      <button id="mobile-menu-btn" class="p-2 rounded-lg hover:bg-navy-800">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
      </button>
    </div>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="hidden fixed inset-0 z-40 lg:hidden">
      <div class="absolute inset-0 bg-black/50" id="mobile-menu-overlay"></div>
      <div class="absolute left-0 top-0 bottom-0 w-64 bg-navy-900 text-white flex flex-col">
        <div class="p-6 border-b border-navy-700">
          <p class="font-bold text-sm">INFOHAS Academy — Administration</p>
        </div>
        <nav class="flex-1 p-4 space-y-1">
          <a href="/admin" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-navy-300 hover:bg-navy-800 hover:text-white transition-colors">Tableau de bord</a>
          <a href="/admin/submissions" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium bg-navy-800 text-white">Candidatures</a>
          <a href="/admin/content" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-navy-300 hover:bg-navy-800 hover:text-white transition-colors">Contenu</a>
          <a href="/admin/seo" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-navy-300 hover:bg-navy-800 hover:text-white transition-colors">SEO & Meta</a>
          <a href="/admin/redirects" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-navy-300 hover:bg-navy-800 hover:text-white transition-colors">Redirections</a>
        </nav>
        <div class="p-4 border-t border-navy-700">
          <button id="logout-btn-mobile" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-navy-300 hover:bg-red-900/50 hover:text-red-300 transition-colors">Déconnexion</button>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="flex-1 bg-gray-50 lg:bg-white pt-16 lg:pt-0">
      <div class="p-6 lg:p-8 max-w-7xl">
        <!-- Page Header -->
        <div class="mb-6">
          <h1 class="text-2xl lg:text-3xl font-bold text-navy-900">Candidatures & Messages</h1>
          <p class="text-navy-500 mt-1">Gérez les candidatures et les messages de contact.</p>
        </div>

        <!-- Tabs -->
        <div class="flex gap-1 bg-gray-100 rounded-lg p-1 mb-6 w-fit">
          <button
            id="tab-enrollment"
            class="tab-btn px-4 py-2 rounded-md text-sm font-medium bg-white shadow text-navy-900"
            data-tab="enrollment"
          >
            Candidatures Formation ({enrollmentsList.length})
          </button>
          <button
            id="tab-contact"
            class="tab-btn px-4 py-2 rounded-md text-sm font-medium text-navy-500 hover:text-navy-700"
            data-tab="contact"
          >
            Messages Contact ({contactsList.length})
          </button>
        </div>

        <!-- Filters -->
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <label class="text-sm font-medium text-navy-600">Filtrer par statut:</label>
          <div class="flex gap-2">
            <button class="status-filter px-3 py-1.5 rounded-lg text-xs font-semibold bg-navy-900 text-white" data-status="all">Tous</button>
            <button class="status-filter px-3 py-1.5 rounded-lg text-xs font-semibold bg-gray-100 text-navy-600 hover:bg-gray-200" data-status="new">Nouveau</button>
            <button class="status-filter px-3 py-1.5 rounded-lg text-xs font-semibold bg-gray-100 text-navy-600 hover:bg-gray-200" data-status="read">Lu</button>
            <button class="status-filter px-3 py-1.5 rounded-lg text-xs font-semibold bg-gray-100 text-navy-600 hover:bg-gray-200" data-status="replied">Répondu</button>
            <button class="status-filter px-3 py-1.5 rounded-lg text-xs font-semibold bg-gray-100 text-navy-600 hover:bg-gray-200" data-status="archived">Archivé</button>
          </div>
        </div>

        <!-- Enrollment Table -->
        <div id="panel-enrollment" class="tab-panel">
          <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full" id="table-enrollment">
                <thead>
                  <tr class="border-b border-gray-100 bg-gray-50">
                    <th class="text-left px-6 py-3 text-xs font-semibold text-navy-500 uppercase tracking-wider">Date</th>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-navy-500 uppercase tracking-wider">Nom</th>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-navy-500 uppercase tracking-wider hidden md:table-cell">Email</th>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-navy-500 uppercase tracking-wider hidden lg:table-cell">Programme</th>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-navy-500 uppercase tracking-wider">Statut</th>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-navy-500 uppercase tracking-wider">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-50" id="tbody-enrollment">
                  {enrollmentsList.length === 0 ? (
                    <tr><td colspan="6" class="px-6 py-12 text-center text-navy-400">Aucune candidature trouvée.</td></tr>
                  ) : enrollmentsList.map((sub: Submission) => (
                    <tr class="hover:bg-gray-50 transition-colors submission-row" data-id={sub.id} data-status={sub.status}>
                      <td class="px-6 py-4 text-sm text-navy-500 whitespace-nowrap">{formatDate(sub.created_at)}</td>
                      <td class="px-6 py-4">
                        <p class="text-sm font-medium text-navy-800">{sub.first_name} {sub.last_name}</p>
                        {sub.phone && <p class="text-xs text-navy-400">{sub.phone}</p>}
                      </td>
                      <td class="px-6 py-4 text-sm text-navy-500 hidden md:table-cell">{sub.email}</td>
                      <td class="px-6 py-4 text-sm text-navy-500 hidden lg:table-cell">{sub.program || '—'}</td>
                      <td class="px-6 py-4">
                        <span class="status-badge inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold" data-status={sub.status}>
                          {sub.status === 'new' ? 'Nouveau' : sub.status === 'read' ? 'Lu' : sub.status === 'replied' ? 'Répondu' : sub.status === 'archived' ? 'Archivé' : sub.status}
                        </span>
                      </td>
                      <td class="px-6 py-4">
                        <div class="flex items-center gap-1">
                          <button class="view-btn p-1.5 rounded-lg text-navy-400 hover:bg-primary-50 hover:text-primary-600 transition-colors" title="Voir détails" data-id={sub.id}>
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                          </button>
                          <button class="status-btn p-1.5 rounded-lg text-navy-400 hover:bg-green-50 hover:text-green-600 transition-colors" title="Marquer comme lu" data-id={sub.id} data-new-status="read">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                          </button>
                          <button class="status-btn p-1.5 rounded-lg text-navy-400 hover:bg-blue-50 hover:text-blue-600 transition-colors" title="Marquer comme répondu" data-id={sub.id} data-new-status="replied">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                          </button>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Contact Table -->
        <div id="panel-contact" class="tab-panel hidden">
          <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full" id="table-contact">
                <thead>
                  <tr class="border-b border-gray-100 bg-gray-50">
                    <th class="text-left px-6 py-3 text-xs font-semibold text-navy-500 uppercase tracking-wider">Date</th>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-navy-500 uppercase tracking-wider">Nom</th>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-navy-500 uppercase tracking-wider hidden md:table-cell">Email</th>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-navy-500 uppercase tracking-wider hidden lg:table-cell">Message</th>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-navy-500 uppercase tracking-wider">Statut</th>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-navy-500 uppercase tracking-wider">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-50" id="tbody-contact">
                  {contactsList.length === 0 ? (
                    <tr><td colspan="6" class="px-6 py-12 text-center text-navy-400">Aucun message trouvé.</td></tr>
                  ) : contactsList.map((sub: Submission) => (
                    <tr class="hover:bg-gray-50 transition-colors submission-row" data-id={sub.id} data-status={sub.status}>
                      <td class="px-6 py-4 text-sm text-navy-500 whitespace-nowrap">{formatDate(sub.created_at)}</td>
                      <td class="px-6 py-4">
                        <p class="text-sm font-medium text-navy-800">{sub.first_name} {sub.last_name}</p>
                        {sub.phone && <p class="text-xs text-navy-400">{sub.phone}</p>}
                      </td>
                      <td class="px-6 py-4 text-sm text-navy-500 hidden md:table-cell">{sub.email}</td>
                      <td class="px-6 py-4 text-sm text-navy-500 hidden lg:table-cell max-w-[200px] truncate">{sub.message || '—'}</td>
                      <td class="px-6 py-4">
                        <span class="status-badge inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold" data-status={sub.status}>
                          {sub.status === 'new' ? 'Nouveau' : sub.status === 'read' ? 'Lu' : sub.status === 'replied' ? 'Répondu' : sub.status === 'archived' ? 'Archivé' : sub.status}
                        </span>
                      </td>
                      <td class="px-6 py-4">
                        <div class="flex items-center gap-1">
                          <button class="view-btn p-1.5 rounded-lg text-navy-400 hover:bg-primary-50 hover:text-primary-600 transition-colors" title="Voir détails" data-id={sub.id}>
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                          </button>
                          <button class="status-btn p-1.5 rounded-lg text-navy-400 hover:bg-green-50 hover:text-green-600 transition-colors" title="Marquer comme lu" data-id={sub.id} data-new-status="read">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                          </button>
                          <button class="status-btn p-1.5 rounded-lg text-navy-400 hover:bg-blue-50 hover:text-blue-600 transition-colors" title="Marquer comme répondu" data-id={sub.id} data-new-status="replied">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                          </button>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Server data for client-side JS -->
  <div id="server-data" data-enrollments={JSON.stringify(enrollmentsList)} data-contacts={JSON.stringify(contactsList)} class="hidden"></div>

  <!-- Detail Modal -->
  <div id="detail-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/50" id="modal-overlay"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
      <div class="sticky top-0 bg-white border-b border-gray-100 px-6 py-4 flex items-center justify-between rounded-t-2xl">
        <h3 class="text-lg font-bold text-navy-900" id="modal-title">Détails de la candidature</h3>
        <button id="modal-close" class="p-2 rounded-lg hover:bg-gray-100 transition-colors">
          <svg class="w-5 h-5 text-navy-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <div id="modal-content" class="px-6 py-6 space-y-4">
        <!-- Filled by JS -->
      </div>
    </div>
  </div>
</Layout>

<style>
  .status-badge[data-status="new"] { background-color: #dbeafe; color: #1d4ed8; }
  .status-badge[data-status="read"] { background-color: #f3f4f6; color: #4b5563; }
  .status-badge[data-status="replied"] { background-color: #dcfce7; color: #15803d; }
  .status-badge[data-status="archived"] { background-color: #fee2e2; color: #dc2626; }
</style>

<script>
  // ---- Data from server (embedded in data attributes) ----
  const serverDataEl = document.getElementById('server-data');
  const enrollmentsData = JSON.parse(serverDataEl?.getAttribute('data-enrollments') || '[]');
  const contactsData = JSON.parse(serverDataEl?.getAttribute('data-contacts') || '[]');

  // ---- Logout ----
  async function doLogout() {
    try { await fetch('/api/admin/logout', { method: 'POST' }); } catch {}
    window.location.href = '/admin/login';
  }
  document.getElementById('logout-btn')?.addEventListener('click', doLogout);
  document.getElementById('logout-btn-mobile')?.addEventListener('click', doLogout);

  // ---- Mobile Menu ----
  const mobileMenu = document.getElementById('mobile-menu');
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));
  document.getElementById('mobile-menu-overlay')?.addEventListener('click', () => mobileMenu?.classList.add('hidden'));

  // ---- Tabs ----
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabPanels = document.querySelectorAll('.tab-panel');
  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      tabBtns.forEach(b => { b.classList.remove('bg-white', 'shadow', 'text-navy-900'); b.classList.add('text-navy-500'); });
      btn.classList.add('bg-white', 'shadow', 'text-navy-900');
      btn.classList.remove('text-navy-500');
      const tab = btn.getAttribute('data-tab');
      tabPanels.forEach(p => p.classList.add('hidden'));
      document.getElementById(`panel-${tab}`)?.classList.remove('hidden');
    });
  });

  // ---- Status Filters ----
  const statusFilters = document.querySelectorAll('.status-filter');
  let activeFilter = 'all';
  statusFilters.forEach(btn => {
    btn.addEventListener('click', () => {
      statusFilters.forEach(b => { b.classList.remove('bg-navy-900', 'text-white'); b.classList.add('bg-gray-100', 'text-navy-600'); });
      btn.classList.add('bg-navy-900', 'text-white');
      btn.classList.remove('bg-gray-100', 'text-navy-600');
      activeFilter = btn.getAttribute('data-status') || 'all';
      document.querySelectorAll('.submission-row').forEach(row => {
        const rowStatus = row.getAttribute('data-status');
        if (activeFilter === 'all' || rowStatus === activeFilter) {
          (row as HTMLElement).style.display = '';
        } else {
          (row as HTMLElement).style.display = 'none';
        }
      });
    });
  });

  // ---- Update Status ----
  document.querySelectorAll('.status-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      const newStatus = btn.getAttribute('data-new-status');
      if (!id || !newStatus) return;

      try {
        const res = await fetch('/api/admin/submissions', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: parseInt(id), status: newStatus }),
        });

        if (res.ok) {
          const row = btn.closest('tr');
          if (row) {
            row.setAttribute('data-status', newStatus);
            const badge = row.querySelector('.status-badge');
            if (badge) {
              badge.setAttribute('data-status', newStatus);
              const labels: Record<string, string> = { new: 'Nouveau', read: 'Lu', replied: 'Répondu', archived: 'Archivé' };
              badge.textContent = labels[newStatus] || newStatus;
            }
          }
        }
      } catch (err) {
        console.error('Failed to update status:', err);
      }
    });
  });

  // ---- View Detail Modal ----
  const allSubmissions = [...enrollmentsData, ...contactsData];
  const modal = document.getElementById('detail-modal');
  const modalTitle = document.getElementById('modal-title');
  const modalContent = document.getElementById('modal-content');

  document.querySelectorAll('.view-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = parseInt(btn.getAttribute('data-id') || '0');
      const sub = allSubmissions.find(s => s.id === id);
      if (!sub || !modal || !modalTitle || !modalContent) return;

      modalTitle.textContent = sub.type === 'enrollment' ? `Candidature #${sub.id}` : `Message #${sub.id}`;

      const statusLabels: Record<string, string> = { new: 'Nouveau', read: 'Lu', replied: 'Répondu', archived: 'Archivé' };
      const typeLabels: Record<string, string> = { enrollment: 'Candidature', contact: 'Contact' };

      let html = `
        <div class="flex items-center gap-2 mb-4">
          <span class="badge bg-primary-100 text-primary-700">${typeLabels[sub.type] || sub.type}</span>
          <span class="status-badge inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold" data-status="${sub.status}">${statusLabels[sub.status] || sub.status}</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold text-navy-400 uppercase mb-1">Nom complet</p>
            <p class="text-sm font-medium text-navy-800">${sub.first_name} ${sub.last_name}</p>
          </div>
          <div>
            <p class="text-xs font-semibold text-navy-400 uppercase mb-1">Email</p>
            <p class="text-sm text-navy-800"><a href="mailto:${sub.email}" class="text-primary-600 hover:underline">${sub.email}</a></p>
          </div>
          ${sub.phone ? `<div><p class="text-xs font-semibold text-navy-400 uppercase mb-1">Téléphone</p><p class="text-sm text-navy-800">${sub.phone}</p></div>` : ''}
          ${sub.program ? `<div><p class="text-xs font-semibold text-navy-400 uppercase mb-1">Programme</p><p class="text-sm text-navy-800">${sub.program}</p></div>` : ''}
          ${sub.education_level ? `<div><p class="text-xs font-semibold text-navy-400 uppercase mb-1">Niveau d'études</p><p class="text-sm text-navy-800">${sub.education_level}</p></div>` : ''}
          ${sub.date_of_birth ? `<div><p class="text-xs font-semibold text-navy-400 uppercase mb-1">Date de naissance</p><p class="text-sm text-navy-800">${sub.date_of_birth}</p></div>` : ''}
          ${sub.city ? `<div><p class="text-xs font-semibold text-navy-400 uppercase mb-1">Ville</p><p class="text-sm text-navy-800">${sub.city}</p></div>` : ''}
          <div>
            <p class="text-xs font-semibold text-navy-400 uppercase mb-1">Date de soumission</p>
            <p class="text-sm text-navy-800">${new Date(sub.created_at).toLocaleString('fr-FR')}</p>
          </div>
        </div>
        ${sub.message ? `<div class="mt-4"><p class="text-xs font-semibold text-navy-400 uppercase mb-1">Message</p><p class="text-sm text-navy-800 bg-gray-50 rounded-lg p-4 whitespace-pre-wrap">${sub.message}</p></div>` : ''}
      `;

      modalContent.innerHTML = html;
      modal.classList.remove('hidden');
    });
  });

  document.getElementById('modal-close')?.addEventListener('click', () => modal?.classList.add('hidden'));
  document.getElementById('modal-overlay')?.addEventListener('click', () => modal?.classList.add('hidden'));
</script>
