---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'Programmes', href: '/programmes' },
  { label: 'Inscription', href: '/inscription' },
  { label: 'Contact', href: '/contact' },
  { label: 'À Propos', href: '/a-propos' },
];

const programLinks = [
  { label: 'Hôtesse de l\'Air', href: '/programmes#hotesse-de-lair' },
  { label: 'Steward', href: '/programmes#steward' },
  { label: 'Hôtesse d\'Accueil', href: '/programmes#hotesse-accueil' },
  { label: 'Agent Aéroportuaire', href: '/programmes#agent-aeroportuaire' },
];
---

<footer class="bg-navy-900 text-white" role="contentinfo">
  <!-- Main Footer -->
  <div class="container-max section-padding pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-5">
          <div class="w-11 h-11 bg-gradient-to-br from-primary-500 to-primary-700 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
          </div>
          <div>
            <span class="text-xl font-bold tracking-tight">INFOHAS</span>
            <span class="block text-xs font-medium text-primary-400 tracking-widest uppercase -mt-1">Academy</span>
          </div>
        </a>
        <p class="text-navy-300 text-sm leading-relaxed mb-6">
          Académie de référence au Maroc pour la formation du personnel navigant commercial depuis 1996.
          Préparez votre carrière dans l'aviation internationale avec un diplôme accrédité par l'État.
        </p>
        <!-- Social Links -->
        <div class="flex gap-3">
          <a href="https://www.facebook.com/GroupeInfohas" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-navy-800 hover:bg-primary-600 rounded-lg flex items-center justify-center transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/infohas.cabincrew/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-navy-800 hover:bg-primary-600 rounded-lg flex items-center justify-center transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://x.com/Groupeinfohas" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-navy-800 hover:bg-primary-600 rounded-lg flex items-center justify-center transition-colors" aria-label="X / Twitter">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company-beta/5237641/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-navy-800 hover:bg-primary-600 rounded-lg flex items-center justify-center transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://www.youtube.com/user/HOTESSE12" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-navy-800 hover:bg-primary-600 rounded-lg flex items-center justify-center transition-colors" aria-label="YouTube">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-primary-400 mb-5">Navigation</h3>
        <ul class="space-y-3">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="text-navy-300 hover:text-white transition-colors text-sm flex items-center gap-2 group">
                <svg class="w-4 h-4 text-primary-500 opacity-0 -ml-5 group-hover:opacity-100 group-hover:ml-0 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Programs -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-primary-400 mb-5">Formations</h3>
        <ul class="space-y-3">
          {programLinks.map(link => (
            <li>
              <a href={link.href} class="text-navy-300 hover:text-white transition-colors text-sm flex items-center gap-2 group">
                <svg class="w-4 h-4 text-primary-500 opacity-0 -ml-5 group-hover:opacity-100 group-hover:ml-0 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-primary-400 mb-5">Contact</h3>
        <ul class="space-y-4 text-sm text-navy-300">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span>15 Rue Demnate, Hassan, Rabat, Maroc</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <a href="tel:+212537762025" class="hover:text-white transition-colors">+212 537 76 20 25</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            <a href="mailto:contact@infohas.ma" class="hover:text-white transition-colors">contact@infohas.ma</a>
          </li>
        </ul>

        <!-- CTA -->
        <div class="mt-6 p-4 bg-navy-800 rounded-xl border border-navy-700">
          <p class="text-sm text-navy-300 mb-3">Inscriptions ouvertes pour la prochaine session</p>
          <a href="/inscription" class="btn-primary text-sm px-5 py-2.5 w-full text-center">
            Postuler Maintenant
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-navy-800">
    <div class="container-max px-4 sm:px-6 lg:px-8 py-5 flex flex-col md:flex-row items-center justify-between gap-3 text-sm text-navy-400">
      <p>&copy; {currentYear} INFOHAS Academy. Tous droits réservés.</p>
      <div class="flex items-center gap-4">
        <a href="/mentions-legales" class="hover:text-white transition-colors">Mentions légales</a>
        <span class="text-navy-600">|</span>
        <a href="/plan-du-site" class="hover:text-white transition-colors">Plan du site</a>
      </div>
    </div>
  </div>
</footer>
