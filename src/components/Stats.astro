---
const stats = [
  { value: '30+', label: "Années d'Excellence", icon: 'award' },
  { value: '3 500+', label: 'Diplômés en Vol', icon: 'users' },
  { value: '95%', label: 'Taux de Placement', icon: 'chart' },
  { value: '98%', label: 'Réussite Examens', icon: 'check' },
];
---

<section class="relative -mt-16 z-20 container-max px-4 sm:px-6 lg:px-8">
  <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-6 md:p-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
      {stats.map((stat, i) => (
        <div class="text-center animate-on-scroll" style={`animation-delay: ${i * 0.1}s`}>
          <div class="w-12 h-12 mx-auto mb-3 bg-primary-50 rounded-xl flex items-center justify-center">
            {stat.icon === 'award' && (
              <svg class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
            )}
            {stat.icon === 'users' && (
              <svg class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
            )}
            {stat.icon === 'chart' && (
              <svg class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
            )}
            {stat.icon === 'check' && (
              <svg class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            )}
          </div>
          <div class="text-2xl md:text-3xl font-extrabold text-navy-900 mb-1">{stat.value}</div>
          <div class="text-xs md:text-sm text-navy-500 font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
