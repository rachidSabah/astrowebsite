---
interface Props {
  title: string;
  subtitle?: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  badge?: string;
  backgroundImage?: string;
}

const { title, subtitle, ctaPrimary, ctaSecondary, badge, backgroundImage } = Astro.props;
---

<section class="relative min-h-[85vh] flex items-center overflow-hidden bg-navy-950">
  <!-- Background -->
  <div class="absolute inset-0">
    {backgroundImage ? (
      <img
        src={backgroundImage}
        alt=""
        class="w-full h-full object-cover opacity-30"
        loading="eager"
        decoding="async"
      />
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-primary-950 to-navy-900"></div>
    )}
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/90 via-navy-950/60 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-navy-950/50 via-transparent to-navy-950/30"></div>
  </div>

  <!-- Decorative Elements -->
  <div class="absolute top-20 right-20 w-72 h-72 bg-primary-500/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 left-10 w-96 h-96 bg-accent-500/5 rounded-full blur-3xl"></div>

  <div class="container-max relative z-10 py-20 md:py-28">
    <div class="max-w-3xl">
      {badge && (
        <div class="animate-fade-in mb-6">
          <span class="badge-primary text-sm px-4 py-2">
            <span class="inline-block w-2 h-2 bg-primary-500 rounded-full mr-2 animate-pulse"></span>
            {badge}
          </span>
        </div>
      )}

      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.1] mb-6 animate-fade-in text-balance" style="animation-delay: 0.1s">
        {title}
      </h1>

      {subtitle && (
        <p class="text-lg sm:text-xl text-navy-200 leading-relaxed max-w-2xl mb-10 animate-fade-in" style="animation-delay: 0.2s">
          {subtitle}
        </p>
      )}

      <div class="flex flex-wrap gap-4 animate-fade-in" style="animation-delay: 0.3s">
        {ctaPrimary && (
          <a href={ctaPrimary.href} class="btn-primary text-base px-8 py-4">
            {ctaPrimary.label}
            <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        )}
        {ctaSecondary && (
          <a href={ctaSecondary.href} class="btn-secondary text-base px-8 py-4 border-white/20 text-white hover:bg-white/10">
            {ctaSecondary.label}
          </a>
        )}
      </div>

      <!-- Trust Indicators -->
      <div class="mt-14 flex flex-wrap items-center gap-6 md:gap-10 animate-fade-in" style="animation-delay: 0.5s">
        <div class="flex items-center gap-2">
          <div class="flex -space-x-2">
            <div class="w-8 h-8 rounded-full bg-primary-400 border-2 border-navy-950 flex items-center justify-center text-xs font-bold text-white">F</div>
            <div class="w-8 h-8 rounded-full bg-accent-400 border-2 border-navy-950 flex items-center justify-center text-xs font-bold text-white">A</div>
            <div class="w-8 h-8 rounded-full bg-primary-300 border-2 border-navy-950 flex items-center justify-center text-xs font-bold text-white">M</div>
          </div>
          <div class="text-sm text-navy-300">
            <span class="font-semibold text-white">3 500+</span> diplômés
          </div>
        </div>
        <div class="flex items-center gap-2 text-sm text-navy-300">
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <span class="font-semibold text-white">95%</span> de placement
        </div>
        <div class="text-sm text-navy-300">
          <span class="font-semibold text-white">30 ans</span> d'expertise
        </div>
      </div>
    </div>
  </div>
</section>
